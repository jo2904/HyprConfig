{
  "layer": "top",

  "margin-top": 1,
  "margin-bottom": 0,
  "margin-left": 3,
  "margin-right": 3,

  "reload_style_on_change": true,
  "position": "top",
  "height": 28,
  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right": [
    "group/tray-expander",
    "bluetooth",
    "network",
    "group/pulseaudio",
    "group/battery"
  ],

  "clock": {
    "format": "{:%H:%M}",
    "format-alt": "{:%A, %d %B %Y  |  %H:%M}",
    "tooltip": true,
    "tooltip-format": "<span size='9pt' font='monospace'>{calendar}</span>",
    "on-click-right": "xdg-open https://trystop.eu/apps/calendar/dayGridMonth/now",

    "calendar": {
      "mode": "month",
      "weeks-pos": "left",
      "on-scroll": 1,
      "format": {
        "months": "<b>{}</b>",
        "weekdays": "{}",
        "days": "{}",
        "weeks": "S{}",
        "today": "<b><u>{}</u></b>"
      }
    }
  },

  "network": {
    "format-icons": ["َ°¤¯", "َ°¤ں", "َ°¤¢", "َ°¤¥", "َ°¤¨"],
    "format": "{icon}",
    "format-wifi": "{icon}",
    "format-ethernet": "َ°€‚",
    "format-disconnected": "َ°–ھ",
    "tooltip-format-wifi": "{essid} ({frequency} GHz)\nâ‡£{bandwidthDownBytes}  â‡،{bandwidthUpBytes}",
    "tooltip-format-ethernet": "â‡£{bandwidthDownBytes}  â‡،{bandwidthUpBytes}",
    "tooltip-format-disconnected": "Disconnected",
    "interval": 3,
    "spacing": 1,
    "on-click": "kitty --class Gazelle gazelle"
  },

  "group/battery": {
    "orientation": "horizontal",
    "modules": ["battery", "power-profiles-daemon"],
    "drawer": {
      "transition-left-to-right": true
    }
  },

  "battery": {
    "bat": "BAT0",
    "adapter": "AC",
    "format": "{icon} {capacity}%",
    "format-discharging": "{icon} {capacity}%",
    "format-charging": "{icon} {capacity}%",
    "format-plugged": "ï‡¦",
    "format-icons": {
      "charging": ["َ°¢œ", "َ°‚†", "َ°‚‡", "َ°‚ˆ", "َ°¢‌", "َ°‚‰", "َ°¢‍", "َ°‚ٹ", "َ°‚‹", "َ°‚…"],
      "default": ["َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"]
    },
    "format-full": "َ°‚…",
    "format-time": "{H} hr {M} min",
    "interval": 5,
    "tooltip-format": "{capacity}% ({time})",
    "tooltip-format-charging": "Charging: {capacity}% ({time})",
    "states": {
      "warning": 20,
      "critical": 10
    },
    "events": {
      "on-discharging-warning": "notify-send 'Low Battery' '{capacity}% battery remaining'",
      "on-discharging-critical": "notify-send 'Low Battery' '{capacity}% battery remaining' -u critical",
      "on-charging-100": "notify-send 'Battery full' 'Battery is at {capacity}%'"
    }
  },

  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "ïƒ§",
      "performance": "ïƒ§",
      "balanced": "ï‰ژ",
      "power-saver": "ïپ¬"
    }
  },

  "bluetooth": {
    "format": "ïٹ”",
    "format-disabled": "َ°‚²",
    "format-connected": "ïٹ”",
    "format-on": "َ°‚¯",
    "format-off": "َ°‚²",
    "tooltip-format": "Devices connected: {num_connections}",
    "on-click": "kitty --class floating bluetui"
  },

  "group/pulseaudio": {
    "orientation": "horizontal",
    "modules": ["pulseaudio#output", "pulseaudio#input", "custom/mixer"],
    "drawer": {
      "transition-left-to-right": true
    }
  },

  /*-------------------
		output device
	-------------------*/

  "pulseaudio#output": {
    "format": "{icon} {volume}%",
    "format-muted": "{icon}",

    "format-icons": {
      "default": ["َ°•؟", "َ°–€", "َ°•¾"],
      "default-muted": "َ°‌ں",
      "headphone": "َ°‹‹",
      "headphone-muted": "َ°ںژ",
      "headset": "َ°‹ژ",
      "headset-muted": "َ°‹گ"
    },

    "on-click": "~/.config/scripts/volume.sh output mute",

    "on-scroll-up": "~/.config/scripts/volume.sh output raise",
    "on-scroll-down": "~/.config/scripts/volume.sh output lower",

    "tooltip-format": "Output Device: {desc}"
  },

  /*----------------
		microphone
	----------------*/

  "pulseaudio#input": {
    "format": "{format_source}",

    "format-source": "َ°چ¬ {volume}%",
    "format-source-muted": "َ°چ­",

    "on-click": "~/.config/scripts/volume.sh input mute",

    "on-scroll-up": "~/.config/scripts/volume.sh input raise",
    "on-scroll-down": "~/.config/scripts/volume.sh input lower",

    "tooltip-format": "Input Device: {desc}"
  },

  /*-------------------
    mixer icon
  -------------------*/
  "custom/mixer": {
    "format": "َ°’“", // tu peux changer lâ€™icأ´ne (celle-ci est souvent utilisأ©e pour le mixage)
    "tooltip": "Ouvrir le mixeur audio (Wiremix)",
    "on-click": "kitty --class floating wiremix"
  },

  "group/tray-expander": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 600,
      "children-class": "tray-group-item"
    },
    "modules": ["custom/expand-icon", "tray"]
  },

  "custom/expand-icon": {
    "format": "ï‚‹ ",
    "tooltip": false
  },

  "tray": {
    // "icon-size": 12
    // "spacing": 12
  }
}
